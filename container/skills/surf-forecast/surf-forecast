#!/usr/bin/env node

const fs = require('fs');
const path = require('path');

const COMPASS = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];

function compassDir(deg) {
  return COMPASS[Math.round(deg / 22.5) % 16];
}

function angleDiff(a, b) {
  const d = Math.abs(((a - b) % 360 + 360) % 360);
  return d > 180 ? 360 - d : d;
}

// --- Spot Profiles ---

function loadSpotProfiles() {
  const paths = [
    '/usr/local/share/surf-forecast/spot-profiles.json',
    path.join(__dirname, 'spot-profiles.json'),
  ];
  for (const p of paths) {
    try { return JSON.parse(fs.readFileSync(p, 'utf8')); } catch {}
  }
  return [];
}

function matchSpot(location, profiles) {
  const lower = location.toLowerCase();
  for (const spot of profiles) {
    for (const alias of spot.aliases) {
      if (lower.includes(alias)) return spot;
    }
  }
  return null;
}

// --- Period Multiplier ---

function periodMultiplier(period) {
  if (period < 6) return 0.3;
  if (period < 8) return 0.5;
  if (period < 10) return 0.8;
  if (period < 13) return 1.0;
  if (period < 16) return 1.3;
  return 1.5;
}

// --- Sub-scores ---

function swellQualityScore(swellH, swellP) {
  const energy = swellH * swellH * periodMultiplier(swellP);
  if (energy < 0.2) return 1;
  if (energy < 0.6) return 2;
  if (energy < 1.5) return 3;
  if (energy < 3.0) return 4;
  return 5;
}

function isInSwellWindow(dir, window) {
  const [min, max] = window;
  if (min <= max) return dir >= min && dir <= max;
  // wraps through 360
  return dir >= min || dir <= max;
}

function swellDirectionScore(swellDir, spot) {
  if (!spot) return 4; // no profile = neutral default
  const [min, max] = spot.swellWindow;
  if (isInSwellWindow(swellDir, [min, max])) return 5;
  // distance outside window
  const distMin = angleDiff(swellDir, min);
  const distMax = angleDiff(swellDir, max);
  const dist = Math.min(distMin, distMax);
  // but only if not already inside
  if (dist <= 15) return 3;
  if (dist <= 45) return 1.5;
  return 0; // forces final rating to 1
}

function windScore(windSpeed, windDir, spot, swellDir) {
  // Glassy
  if (windSpeed < 5) return 5;

  if (spot) {
    const offshoreDir = (spot.coastFacing + 180) % 360;
    const angle = angleDiff(windDir, offshoreDir);

    if (angle < 30) {
      // Offshore
      return windSpeed > 25 ? 4 : 5;
    } else if (angle < 60) {
      // Cross-offshore
      return windSpeed > 20 ? 3 : 4;
    } else if (angle < 120) {
      // Cross-shore
      if (windSpeed > 25) return 1;
      if (windSpeed > 15) return 2;
      return 3;
    } else if (angle < 150) {
      // Cross-onshore
      return windSpeed > 15 ? 1 : 2;
    } else {
      // Onshore
      if (windSpeed < 10) return 2;
      if (windSpeed < 20) return 1;
      return 0.5;
    }
  }

  // Fallback: wind vs swell direction (old heuristic)
  const diff = angleDiff(windDir, swellDir);
  let score = 3;
  if (diff >= 150) score = 5;
  else if (diff >= 60) score = 3;
  else score = 1.5;

  if (windSpeed > 25) score = Math.max(0.5, score - 1.5);
  else if (windSpeed > 15) score = Math.max(0.5, score - 0.5);
  return score;
}

function getDefaultTideRange(breakType) {
  if (breakType === 'reef') return [0.1, 0.5];
  if (breakType === 'point') return [0.2, 0.6];
  return [0.4, 0.8]; // beach
}

function tideScore(normalizedTide, spot) {
  if (normalizedTide == null || !spot) return 3; // no data or no profile
  const range = spot.optimalTide || getDefaultTideRange(spot.breakType);
  const [lo, hi] = range;
  if (normalizedTide >= lo && normalizedTide <= hi) return 5;
  const distOutside = normalizedTide < lo ? lo - normalizedTide : normalizedTide - hi;
  if (distOutside <= 0.15) return 3;
  return 1.5;
}

// --- Composite Rating ---

function rateConditions(swellH, swellP, windSpeed, windDir, swellDir, spot, normalizedTide) {
  const swell = swellQualityScore(swellH, swellP);
  const direction = swellDirectionScore(swellDir, spot);
  const wind = windScore(windSpeed, windDir, spot, swellDir);
  const tide = tideScore(normalizedTide, spot);

  // Veto: swell completely outside window
  if (direction === 0) return { rating: 1, swell, direction, wind, tide };

  // Stage 1: base score from swell factors + tide (wind excluded)
  const base = swell * 0.45 + direction * 0.35 + tide * 0.20;

  // Stage 2: wind acts as a ceiling
  // Wind score 5 = no cap, wind score 0.5 = cap at 1
  const raw = Math.min(base, wind);

  const rating = Math.max(1, Math.min(5, Math.round(raw)));
  return { rating, swell, direction, wind, tide };
}

// --- Wind & Swell Labels ---

function windLabel(windDir, spot) {
  if (!spot) return '';
  const offshoreDir = (spot.coastFacing + 180) % 360;
  const angle = angleDiff(windDir, offshoreDir);
  if (angle < 30) return 'offshore';
  if (angle < 60) return 'cross-off';
  if (angle < 120) return 'cross-shore';
  if (angle < 150) return 'cross-on';
  return 'onshore';
}

function swellWindowSymbol(swellDir, spot) {
  if (!spot) return '';
  if (isInSwellWindow(swellDir, spot.swellWindow)) return '✓';
  const distMin = angleDiff(swellDir, spot.swellWindow[0]);
  const distMax = angleDiff(swellDir, spot.swellWindow[1]);
  const dist = Math.min(distMin, distMax);
  if (dist <= 15) return '~';
  return '✗';
}

// --- Tide helpers ---

function tideStateLabel(normalized) {
  if (normalized == null) return '';
  if (normalized < 0.33) return 'low';
  if (normalized < 0.66) return 'mid';
  return 'high';
}

function computeTideNormals(seaLevels, times) {
  // Group sea levels by date, normalize 0-1 within each day
  const byDate = new Map();
  for (let i = 0; i < times.length; i++) {
    const dateKey = times[i].slice(0, 10);
    if (!byDate.has(dateKey)) byDate.set(dateKey, []);
    byDate.get(dateKey).push({ index: i, val: seaLevels[i] });
  }

  const normals = new Array(times.length).fill(null);
  for (const entries of byDate.values()) {
    const vals = entries.map(e => e.val).filter(v => v != null);
    if (vals.length === 0) continue;
    const min = Math.min(...vals);
    const max = Math.max(...vals);
    const range = max - min;
    for (const e of entries) {
      if (e.val != null && range > 0) {
        normals[e.index] = (e.val - min) / range;
      }
    }
  }
  return normals;
}

function tideMovement(normals, i) {
  // Compare to previous hour to determine rising/falling
  if (i <= 0 || normals[i] == null) return '';
  // Look back up to 2 indices for a non-null value
  for (let j = i - 1; j >= Math.max(0, i - 2); j--) {
    if (normals[j] != null) {
      if (normals[i] > normals[j] + 0.02) return 'rising';
      if (normals[i] < normals[j] - 0.02) return 'falling';
      return '';
    }
  }
  return '';
}

// --- CLI ---

function parseArgs(argv) {
  const args = argv.slice(2);
  let location = '';
  let timezone = '';
  let date = '';

  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--timezone' && args[i + 1]) {
      timezone = args[++i];
    } else if (args[i] === '--date' && args[i + 1]) {
      date = args[++i];
    } else {
      location = location ? `${location} ${args[i]}` : args[i];
    }
  }

  if (!location) {
    console.error('Usage: surf-forecast <location> [--timezone <tz>] [--date YYYY-MM-DD]');
    console.error('Example: surf-forecast "Muizenberg, Cape Town" --date 2026-03-20');
    process.exit(1);
  }

  if (date && !/^\d{4}-\d{2}-\d{2}$/.test(date)) {
    console.error('Error: --date must be in YYYY-MM-DD format');
    process.exit(1);
  }

  if (date) {
    const target = new Date(date + 'T00:00:00');
    const today = new Date(); today.setHours(0, 0, 0, 0);
    const daysAhead = Math.round((target - today) / 86400000);
    if (daysAhead < 0) {
      console.error('Error: --date must be today or in the future');
      process.exit(1);
    }
    if (daysAhead > 7) {
      console.error(`Error: Marine forecast only available up to 8 days ahead (requested ${daysAhead} days)`);
      process.exit(1);
    }
  }

  return { location, timezone, date };
}

async function geocode(location, { multiple = false } = {}) {
  const count = multiple ? 5 : 1;
  const url = `https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(location)}&count=${count}&language=en&format=json`;
  const res = await fetch(url);
  if (!res.ok) throw new Error(`Geocoding failed: ${res.status}`);
  const data = await res.json();
  if (!data.results?.length) throw new Error(`Location not found: ${location}`);
  if (multiple) {
    return data.results.map(r => ({ name: r.name, country: r.country, admin1: r.admin1 || '', lat: r.latitude, lon: r.longitude, timezone: r.timezone }));
  }
  const r = data.results[0];
  return { name: r.name, country: r.country, lat: r.latitude, lon: r.longitude, timezone: r.timezone };
}

async function fetchMarine(lat, lon, timezone, date) {
  // Use GWAM (Global Wave Model) for accurate peak period data
  const params = new URLSearchParams({
    latitude: lat, longitude: lon, timezone,
    models: 'gwam',
    hourly: [
      'wave_height',
      'swell_wave_height', 'swell_wave_period', 'swell_wave_direction',
      'swell_wave_peak_period',
      'secondary_swell_wave_height', 'secondary_swell_wave_period', 'secondary_swell_wave_direction',
    ].join(','),
  });
  if (date) { params.set('start_date', date); params.set('end_date', date); }
  else { params.set('forecast_days', '8'); }
  const res = await fetch(`https://marine-api.open-meteo.com/v1/marine?${params}`);
  if (!res.ok) throw new Error(`Marine API failed: ${res.status}`);
  const data = await res.json();

  // GWAM doesn't provide SST — fetch separately from best_match
  const sstParams = new URLSearchParams({
    latitude: lat, longitude: lon, timezone,
    hourly: 'sea_surface_temperature',
  });
  if (date) { sstParams.set('start_date', date); sstParams.set('end_date', date); }
  else { sstParams.set('forecast_days', '8'); }
  try {
    const sstRes = await fetch(`https://marine-api.open-meteo.com/v1/marine?${sstParams}`);
    if (sstRes.ok) {
      const sstData = await sstRes.json();
      data.hourly.sea_surface_temperature = sstData.hourly.sea_surface_temperature;
    } else {
      data.hourly.sea_surface_temperature = [];
    }
  } catch {
    data.hourly.sea_surface_temperature = [];
  }

  return data;
}

async function fetchWind(lat, lon, timezone, date) {
  const params = new URLSearchParams({
    latitude: lat, longitude: lon, timezone,
    hourly: 'wind_speed_10m,wind_direction_10m,surface_pressure',
  });
  if (date) { params.set('start_date', date); params.set('end_date', date); }
  else { params.set('forecast_days', '8'); }
  const res = await fetch(`https://api.open-meteo.com/v1/forecast?${params}`);
  if (!res.ok) throw new Error(`Weather API failed: ${res.status}`);
  return res.json();
}

async function fetchTide(lat, lon, timezone, date) {
  const params = new URLSearchParams({
    latitude: lat, longitude: lon, timezone,
    hourly: 'sea_level_height_msl',
  });
  if (date) { params.set('start_date', date); params.set('end_date', date); }
  else { params.set('forecast_days', '8'); }
  try {
    const res = await fetch(`https://marine-api.open-meteo.com/v1/marine?${params}`);
    if (!res.ok) return null;
    return res.json();
  } catch { return null; }
}

function formatDate(dateStr) {
  const d = new Date(dateStr + 'T00:00:00');
  const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  return `${days[d.getDay()]} ${d.getDate()} ${months[d.getMonth()]}`;
}

function buildReport(geo, marine, wind, tideData, spot, singleDate) {
  const m = marine.hourly;
  const w = wind.hourly;
  const hasSpot = !!spot;
  const lines = [];

  // Tide normalization
  const seaLevels = tideData?.hourly?.sea_level_height_msl || null;
  const tideNormals = seaLevels ? computeTideNormals(seaLevels, m.time) : null;

  // Use peak period when available, fall back to mean period
  const swellPeriods = (m.swell_wave_peak_period || []).map((pp, i) =>
    pp != null ? pp : (m.swell_wave_period[i] ?? 0)
  );
  if (!m.swell_wave_peak_period) {
    // No peak period array at all, use mean periods
    for (let i = 0; i < m.time.length; i++) {
      swellPeriods[i] = m.swell_wave_period[i] ?? 0;
    }
  }

  // Average sea surface temperature
  const temps = m.sea_surface_temperature.filter(t => t != null);
  const avgSeaTemp = temps.length ? Math.round(temps.reduce((a, b) => a + b, 0) / temps.length) : null;

  // Header
  let header = `Surf: ${geo.name}, ${geo.country}`;
  if (avgSeaTemp != null) header += ` | Sea: ${avgSeaTemp}°C`;
  lines.push(header);

  if (hasSpot) {
    const offshoreCompass = compassDir((spot.coastFacing + 180) % 360);
    const swellMinCompass = compassDir(spot.swellWindow[0]);
    const swellMaxCompass = compassDir(spot.swellWindow[1]);
    lines.push(`${spot.breakType.charAt(0).toUpperCase() + spot.breakType.slice(1)} break facing ${compassDir(spot.coastFacing)} | Best swell: ${swellMinCompass}-${swellMaxCompass} | Offshore wind: ${offshoreCompass}`);
    if (spot.notes) lines.push(spot.notes);
    lines.push('📍 Matched local spot profile — ratings use local knowledge for this break.');
  } else {
    lines.push('ℹ️ No local spot profile found — returning raw data without condition ratings.');
  }

  // Current conditions (multi-day mode only)
  if (!singleDate) {
    const now = new Date();
    const nowHour = m.time.findIndex(t => new Date(t) >= now);
    if (nowHour >= 0) {
      const time = m.time[nowHour].slice(11, 16);
      const waveH = m.wave_height[nowHour] ?? 0;
      const swellH = m.swell_wave_height[nowHour] ?? 0;
      const swellP = swellPeriods[nowHour];
      const swellD = m.swell_wave_direction[nowHour] ?? 0;
      const windS = w.wind_speed_10m[nowHour] ?? 0;
      const windD = w.wind_direction_10m[nowHour] ?? 0;
      const tn = tideNormals ? tideNormals[nowHour] : null;

      lines.push('');
      lines.push(`Current (${time})`);
      let swellLine = `Waves: ${waveH.toFixed(1)}m | Swell: ${swellH.toFixed(1)}m @ ${Math.round(swellP)}s from ${compassDir(swellD)}`;
      if (hasSpot) swellLine += ` ${swellWindowSymbol(swellD, spot)}`;
      lines.push(swellLine);

      let windLine = `Wind: ${Math.round(windS)} km/h ${compassDir(windD)}`;
      if (hasSpot) windLine += ` (${windLabel(windD, spot)})`;

      if (hasSpot) {
        const result = rateConditions(swellH, swellP, windS, windD, swellD, spot, tn);
        windLine += ` | Rating: ${result.rating}/5`;
      }
      lines.push(windLine);
    }
  }

  // Group by date
  const byDate = new Map();
  for (let i = 0; i < m.time.length; i++) {
    const hour = parseInt(m.time[i].slice(11, 13), 10);
    if (hour < 6 || hour > 18 || hour % 2 !== 0) continue;
    const dateKey = m.time[i].slice(0, 10);
    if (!byDate.has(dateKey)) byDate.set(dateKey, []);
    byDate.get(dateKey).push(i);
  }

  for (const [dateKey, indices] of byDate) {
    lines.push('');
    lines.push(`Hourly — ${formatDate(dateKey)}`);

    for (const i of indices) {
      const time = m.time[i].slice(11, 16);
      const waveH = (m.wave_height[i] ?? 0).toFixed(1);
      const swellH = m.swell_wave_height[i] ?? 0;
      const swellP = swellPeriods[i];
      const swellDRaw = m.swell_wave_direction[i] ?? 0;
      const swellDStr = compassDir(swellDRaw);
      const windS = w.wind_speed_10m[i] ?? 0;
      const windDRaw = w.wind_direction_10m[i] ?? 0;
      const windDStr = compassDir(windDRaw);
      const tn = tideNormals ? tideNormals[i] : null;

      let line = `${time}  ${waveH}m  ${swellH.toFixed(1)}m @ ${Math.round(swellP)}s ${swellDStr}`;

      if (hasSpot) {
        line += ` ${swellWindowSymbol(swellDRaw, spot)}`;
      }

      line += `  ${Math.round(windS)} km/h ${windDStr}`;

      if (hasSpot) {
        line += ` (${windLabel(windDRaw, spot)})`;
      }

      // Tide info
      if (tideNormals && tn != null) {
        const movement = tideMovement(tideNormals, i);
        const state = tideStateLabel(tn);
        line += `  ${movement ? movement + ' ' : ''}${state}`;
      }

      // Rating (only with spot profile)
      if (hasSpot) {
        const result = rateConditions(swellH, swellP, windS, windDRaw, swellDRaw, spot, tn);
        line += `  ${result.rating}/5`;
      }

      lines.push(line);
    }
  }

  // Secondary swell info if significant
  if (hasSpot && m.secondary_swell_wave_height) {
    const secSwells = [];
    for (let i = 0; i < m.time.length; i++) {
      const sh = m.secondary_swell_wave_height[i];
      if (sh != null && sh > 0.3) {
        secSwells.push({ h: sh, p: m.secondary_swell_wave_period[i], d: m.secondary_swell_wave_direction[i] });
      }
    }
    if (secSwells.length > 0) {
      const avgH = secSwells.reduce((a, s) => a + s.h, 0) / secSwells.length;
      const avgP = secSwells.reduce((a, s) => a + (s.p || 0), 0) / secSwells.length;
      const avgD = secSwells[0].d; // representative direction
      lines.push('');
      lines.push(`Secondary swell: ~${avgH.toFixed(1)}m @ ${Math.round(avgP)}s from ${compassDir(avgD)}`);
    }
  }


  return lines.join('\n');
}

async function main() {
  const { location, timezone: tzOverride, date } = parseArgs(process.argv);

  const profiles = loadSpotProfiles();
  const spot = matchSpot(location, profiles);

  // Use spot coords if available, otherwise geocode
  let geo;
  if (spot && spot.lat != null && spot.lon != null) {
    geo = { name: spot.name, country: '', lat: spot.lat, lon: spot.lon, timezone: null };
    // Still geocode to get country and timezone
    try {
      const geoResult = await geocode(location);
      geo.country = geoResult.country;
      geo.timezone = geoResult.timezone;
    } catch {
      // If geocoding fails with spot name, try just the spot name
      try {
        const geoResult = await geocode(spot.name);
        geo.country = geoResult.country;
        geo.timezone = geoResult.timezone;
      } catch {
        geo.country = '';
        geo.timezone = 'UTC';
      }
    }
  } else {
    // No spot profile — check for ambiguous locations
    const candidates = await geocode(location, { multiple: true });
    const countries = new Set(candidates.map(c => c.country));
    if (countries.size > 1) {
      const unique = candidates.filter((c, i, arr) =>
        arr.findIndex(o => o.country === c.country) === i
      );
      console.log(`Multiple locations found for "${location}":\n`);
      unique.forEach((c, i) => {
        const label = [c.name, c.admin1, c.country].filter(Boolean).join(', ');
        console.log(`  ${i + 1}. ${label}`);
      });
      console.log('\nPlease specify a city or country, e.g. "Big Bay, Cape Town"');
      process.exit(0);
    }
    const r = candidates[0];
    geo = { name: r.name, country: r.country, lat: r.lat, lon: r.lon, timezone: r.timezone };
  }

  const tz = tzOverride || geo.timezone;

  const [marine, wind, tideData] = await Promise.all([
    fetchMarine(spot?.lat ?? geo.lat, spot?.lon ?? geo.lon, tz, date),
    fetchWind(spot?.lat ?? geo.lat, spot?.lon ?? geo.lon, tz, date),
    fetchTide(spot?.lat ?? geo.lat, spot?.lon ?? geo.lon, tz, date),
  ]);

  console.log(buildReport(geo, marine, wind, tideData, spot, date));
}

main().catch(err => {
  console.error(`Error: ${err.message}`);
  process.exit(1);
});
