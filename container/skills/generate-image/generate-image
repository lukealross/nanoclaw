#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const https = require('https');

const BFL_API_BASE = 'https://api.bfl.ai/v1';

function httpRequest(url, options, body) {
  return new Promise((resolve, reject) => {
    const parsedUrl = new URL(url);
    const reqOpts = {
      hostname: parsedUrl.hostname,
      path: parsedUrl.pathname + parsedUrl.search,
      method: options.method || 'GET',
      headers: options.headers || {},
    };
    const req = https.request(reqOpts, (res) => {
      let data = '';
      res.on('data', (chunk) => (data += chunk));
      res.on('end', () => {
        if (res.statusCode >= 400) {
          reject(new Error(`HTTP ${res.statusCode}: ${data}`));
        } else {
          resolve({ status: res.statusCode, data });
        }
      });
    });
    req.on('error', reject);
    if (body) req.write(body);
    req.end();
  });
}

function downloadToBuffer(url) {
  return new Promise((resolve, reject) => {
    const parsedUrl = new URL(url);
    const mod = parsedUrl.protocol === 'https:' ? https : require('http');
    mod.get(url, (res) => {
      if (res.statusCode >= 300 && res.statusCode < 400 && res.headers.location) {
        return downloadToBuffer(res.headers.location).then(resolve).catch(reject);
      }
      const chunks = [];
      res.on('data', (chunk) => chunks.push(chunk));
      res.on('end', () => resolve(Buffer.concat(chunks)));
      res.on('error', reject);
    }).on('error', reject);
  });
}

async function pollForResult(pollingUrl, apiKey) {
  const startTime = Date.now();
  const timeout = 120000;
  let interval = 1000;
  const maxInterval = 5000;
  const backoffFactor = 1.5;

  while (Date.now() - startTime < timeout) {
    await new Promise((r) => setTimeout(r, interval));

    const res = await httpRequest(pollingUrl, {
      method: 'GET',
      headers: { 'X-Key': apiKey },
    });

    const result = JSON.parse(res.data);

    if (result.status === 'Ready') {
      return result.result;
    } else if (result.status === 'Error' || result.status === 'Failed') {
      throw new Error(`Generation failed: ${result.error || result.message || 'unknown error'}`);
    }

    // Task still pending/processing — back off
    interval = Math.min(interval * backoffFactor, maxInterval);
  }

  throw new Error('Generation timed out after 120 seconds');
}

function parseArgs(argv) {
  const args = argv.slice(2);
  if (args.length === 0) {
    console.error('Usage:');
    console.error('  generate-image generate "<prompt>" [--aspect 16:9|1:1|9:16|4:3|3:4]');
    console.error('  generate-image edit <image-path> "<instruction>"');
    process.exit(1);
  }

  const subcommand = args[0];
  if (subcommand === 'generate') {
    let prompt = '';
    let aspect = '16:9';
    for (let i = 1; i < args.length; i++) {
      if (args[i] === '--aspect' && args[i + 1]) {
        aspect = args[++i];
      } else if (!prompt) {
        prompt = args[i];
      }
    }
    if (!prompt) {
      console.error('Error: prompt is required for generate');
      process.exit(1);
    }
    return { subcommand: 'generate', prompt, aspect };
  } else if (subcommand === 'edit') {
    const imagePath = args[1];
    const instruction = args[2];
    if (!imagePath || !instruction) {
      console.error('Error: image-path and instruction are required for edit');
      process.exit(1);
    }
    return { subcommand: 'edit', imagePath, instruction };
  } else {
    console.error(`Unknown subcommand: ${subcommand}`);
    process.exit(1);
  }
}

function generateOutputPath() {
  const timestamp = Date.now();
  const random = Math.random().toString(36).slice(2, 8);
  return `attachments/gen-${timestamp}-${random}.jpg`;
}

async function generateImage(prompt, aspect, apiKey) {
  const body = JSON.stringify({
    prompt,
    aspect_ratio: aspect,
  });

  const res = await httpRequest(`${BFL_API_BASE}/flux-2-pro`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-Key': apiKey,
    },
  }, body);

  const { polling_url } = JSON.parse(res.data);
  if (!polling_url) throw new Error('No polling URL returned from API');

  const result = await pollForResult(polling_url, apiKey);
  if (!result || !result.sample) throw new Error('No image URL in result');

  return result.sample;
}

async function editImage(imagePath, instruction, apiKey) {
  // Resolve path relative to /workspace/group/ if not absolute
  const fullPath = path.isAbsolute(imagePath)
    ? imagePath
    : path.join('/workspace/group', imagePath);

  if (!fs.existsSync(fullPath)) {
    throw new Error(`Image not found: ${fullPath}`);
  }

  const imageBuffer = fs.readFileSync(fullPath);
  const ext = path.extname(fullPath).toLowerCase();
  const mimeType = ext === '.png' ? 'image/png' : 'image/jpeg';
  const base64Image = `data:${mimeType};base64,${imageBuffer.toString('base64')}`;

  const body = JSON.stringify({
    prompt: instruction,
    input_image: base64Image,
  });

  const res = await httpRequest(`${BFL_API_BASE}/flux-kontext-pro`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-Key': apiKey,
    },
  }, body);

  const { polling_url } = JSON.parse(res.data);
  if (!polling_url) throw new Error('No polling URL returned from API');

  const result = await pollForResult(polling_url, apiKey);
  if (!result || !result.sample) throw new Error('No image URL in result');

  return result.sample;
}

async function main() {
  const apiKey = process.env.BFL_API_KEY;
  if (!apiKey) {
    console.error('Error: BFL_API_KEY environment variable is not set');
    process.exit(1);
  }

  const parsed = parseArgs(process.argv);
  let imageUrl;

  if (parsed.subcommand === 'generate') {
    imageUrl = await generateImage(parsed.prompt, parsed.aspect, apiKey);
  } else {
    imageUrl = await editImage(parsed.imagePath, parsed.instruction, apiKey);
  }

  // Download the result image
  const imageBuffer = await downloadToBuffer(imageUrl);

  // Save to attachments directory
  const outputPath = generateOutputPath();
  const fullOutputPath = path.join('/workspace/group', outputPath);
  fs.mkdirSync(path.dirname(fullOutputPath), { recursive: true });
  fs.writeFileSync(fullOutputPath, imageBuffer);

  // Print the reference for the agent to include in its response
  console.log(`[Image: ${outputPath}]`);
}

main().catch((err) => {
  console.error(`Error: ${err.message}`);
  process.exit(1);
});
