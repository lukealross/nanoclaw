    review_queue: buildReviewQueue(newRows),
    parse_errors: errors,
    dry_run: !!args['dry-run'],
  }, null, 2));
}

// ---- Periods -------------------------------------------------------------

function parsePeriod(args) {
  if (args.month) {
    const m = String(args.month).match(/^(\d{4})-(\d{2})$/);
    if (!m) die('--month must be YYYY-MM');
    const y = +m[1], mo = +m[2];
    const last = new Date(Date.UTC(y, mo, 0)).getUTCDate();
    return { start: `${m[1]}-${m[2]}-01`, end: `${m[1]}-${m[2]}-${String(last).padStart(2, '0')}`, label: args.month };
  }
  if (args.year) {
    const m = String(args.year).match(/^(\d{4})$/);
    if (!m) die('--year must be YYYY');
    return { start: `${m[1]}-01-01`, end: `${m[1]}-12-31`, label: args.year };
  }
  if (args.from || args.to) {
    return { start: args.from || '0001-01-01', end: args.to || '9999-12-31', label: `${args.from || '*'}..${args.to || '*'}` };
  }
  const now = new Date();
  const y = now.getUTCFullYear();
  const mo = String(now.getUTCMonth() + 1).padStart(2, '0');
  return parsePeriod({ month: `${y}-${mo}` });
}

function inPeriod(date, p) {
  return date >= p.start && date <= p.end;
}

// ---- Subcommand: summary -------------------------------------------------

function cmdSummary(args) {
  const period = parsePeriod(args);
  const groupBy = args['group-by'] || 'category';
  if (!['category', 'subcategory', 'merchant', 'bank'].includes(groupBy)) {
    die('--group-by must be one of: category, subcategory, merchant, bank');
  }
  const includeTransfers = !!args['include-transfers'];
  const refundsAsIncome = !!args['refunds-as-income'];

  const { rows } = readLedger();
  const inRange = rows.filter(r => inPeriod(r.date, period));
  const budget = readBudget();

  let income = 0, expense = 0, fees = 0, transferCount = 0;
  const groups = new Map();
  for (const r of inRange) {
    const amt = parseFloat(r.amount);
    if (Number.isNaN(amt)) continue;
    if (r.tx_type === 'transfer') {
      transferCount++;
      if (!includeTransfers) continue;
    }
    if (r.tx_type === 'income') income += amt;
    else if (r.tx_type === 'refund') {
      if (refundsAsIncome) income += amt;
      else expense += amt; // positive refund pulls negative expense back toward zero
    } else if (r.tx_type === 'fee') { expense += amt; fees += amt; }
    else if (r.tx_type === 'expense') expense += amt;

    let key;
    switch (groupBy) {
      case 'category': key = r.category || '(uncategorised)'; break;
      case 'subcategory': key = `${r.category || '(uncat)'} / ${r.subcategory || '(none)'}`; break;
      case 'merchant': key = r.description_clean || '(unknown)'; break;
      case 'bank': key = r.bank || '(unknown)'; break;
    }
    if (!groups.has(key)) groups.set(key, { key, total: 0, count: 0 });
    const g = groups.get(key);
    g.total += amt;
    g.count++;
  }

  const sorted = [...groups.values()]
    .map(g => ({ ...g, total: round2(g.total) }))
    .sort((a, b) => a.total - b.total);

  for (const g of sorted) {
    if (groupBy === 'category') {
      const matching = budget.filter(b => b.category === g.key);
      if (matching.length > 0) {
        let monthlyEquivalent = 0;
        for (const b of matching) {
          const amt = parseFloat(b.amount) || 0;
          if (b.frequency === 'monthly') monthlyEquivalent += amt;
          else if (b.frequency === 'annual') monthlyEquivalent += amt / 12;
          else if (b.frequency === 'quarterly') monthlyEquivalent += amt / 3;
        }
        g.budget = -round2(monthlyEquivalent);
        g.variance = round2(g.total - g.budget);
      }
    }
  }

  console.log(JSON.stringify({
    period: period.label,
    start: period.start,
    end: period.end,
    group_by: groupBy,
    income_total: round2(income),
    expense_total: round2(expense),
    fees_total: round2(fees),
    net: round2(income + expense),
    groups: sorted,
    transfers_excluded: includeTransfers ? 0 : transferCount,
    transactions_counted: inRange.length - (includeTransfers ? 0 : transferCount),
  }, null, 2));
}

// ---- Subcommand: search --------------------------------------------------

function cmdSearch(args) {
  const { rows } = readLedger();
  const filtered = rows.filter(r => {
    const amt = parseFloat(r.amount);
    if (args.category && r.category !== args.category) return false;
    if (args.subcategory && r.subcategory !== args.subcategory) return false;
    if (args.merchant && !(r.description_clean || '').toLowerCase().includes(args.merchant.toLowerCase())) return false;
    if (args.bank && r.bank !== args.bank) return false;
    if (args.from && r.date < args.from) return false;
    if (args.to && r.date > args.to) return false;
    if (args.min !== undefined && amt < parseFloat(args.min)) return false;
    if (args.max !== undefined && amt > parseFloat(args.max)) return false;
    if (args.text) {
      const t = String(args.text).toLowerCase();
      if (!(r.description_raw || '').toLowerCase().includes(t) &&
          !(r.description_clean || '').toLowerCase().includes(t)) return false;
    }
    if (args.flagged) {
      if (r.flagged_for_review !== 'true') return false;
    }
    return true;
  });
  const limit = args.limit ? parseInt(args.limit, 10) : 50;
  console.log(JSON.stringify({
    total: filtered.length,
    returned: Math.min(filtered.length, limit),
    results: filtered
      .sort((a, b) => b.date.localeCompare(a.date) || b.tx_id.localeCompare(a.tx_id))
      .slice(0, limit)
      .map(r => ({
        tx_id: r.tx_id,
        date: r.date,
        description_raw: r.description_raw,
        description_clean: r.description_clean,
        amount: parseFloat(r.amount),
        currency: r.currency,
        tx_type: r.tx_type,
        category: r.category,
        subcategory: r.subcategory,
        bank: r.bank,
        confidence: r.confidence,
        flagged_for_review: r.flagged_for_review === 'true',
      })),
  }, null, 2));
}

// ---- Subcommand: budget-check --------------------------------------------

function cmdBudgetCheck(args) {
  const period = parsePeriod(args);
  const budget = readBudget();
  const { rows } = readLedger();
  const inRange = rows.filter(r => inPeriod(r.date, period) && r.tx_type !== 'transfer');

  const missing = [];
  const amountChanged = [];
  const discretionaryVariance = [];

  for (const b of budget) {
    if (b.frequency !== 'monthly') continue;
    const expected = parseFloat(b.amount) || 0;
    const matching = inRange.filter(r =>
      r.category === b.category &&
      (!b.subcategory || r.subcategory === b.subcategory)
    );

    if (b.recurring_type === 'debit_order' || b.recurring_type === 'scheduled') {
      if (matching.length === 0) {
        missing.push({
          category: b.category,
          subcategory: b.subcategory || null,
          expected,
          recurring_type: b.recurring_type,
        });
        continue;
      }
      const largest = matching
        .slice()
        .sort((x, y) => Math.abs(parseFloat(y.amount)) - Math.abs(parseFloat(x.amount)))[0];
      const actual = Math.abs(parseFloat(largest.amount));
      const deltaPct = expected > 0 ? ((actual - expected) / expected) * 100 : 0;
      if (Math.abs(deltaPct) > 5) {
        amountChanged.push({
          category: b.category,
          subcategory: b.subcategory || null,
          expected,
          actual: round2(actual),
          delta_pct: round2(deltaPct),
          tx_id: largest.tx_id,
          date: largest.date,
        });
      }
    } else if (b.recurring_type === 'discretionary') {
      const actual = matching
        .filter(r => r.tx_type !== 'income')
        .reduce((s, r) => s + parseFloat(r.amount), 0);
      const variance = actual + expected; // expense is negative; expected is positive budget cap
      const variancePct = expected > 0 ? (variance / expected) * 100 : 0;
      discretionaryVariance.push({
        category: b.category,
        subcategory: b.subcategory || null,
        budget: -expected,
        actual: round2(actual),
        variance: round2(variance),
        variance_pct: round2(variancePct),
      });
    }
  }

  // Unexpected recurring debits: rows with debit-order-like keywords whose
  // category isn't covered by any debit_order/scheduled budget row.
  const debitOrderKeys = new Set(
    budget
      .filter(b => b.recurring_type === 'debit_order' || b.recurring_type === 'scheduled')
      .map(b => `${b.category}|${b.subcategory || '*'}`)
  );
  const unexpectedRecurring = [];
  const seenClean = new Set();
  for (const r of inRange) {
    if (parseFloat(r.amount) >= 0) continue;
    const key = `${r.category}|${r.subcategory || '*'}`;
    const keyAny = `${r.category}|*`;
    if (debitOrderKeys.has(key) || debitOrderKeys.has(keyAny)) continue;
    if (!/DEBIT ORDER|D\/O|MONTHLY|RECURRING/i.test(r.description_raw)) continue;
    const dedupKey = r.description_clean || r.description_raw;
    if (seenClean.has(dedupKey)) continue;
    seenClean.add(dedupKey);
    unexpectedRecurring.push({
      tx_id: r.tx_id,
      description_clean: r.description_clean,
      date: r.date,
      amount: parseFloat(r.amount),
      category: r.category,
    });
  }

  console.log(JSON.stringify({
    period: period.label,
    missing_debit_orders: missing,
    amount_changed: amountChanged,
    unexpected_recurring: unexpectedRecurring,
    discretionary_variance: discretionaryVariance,
  }, null, 2));
}

