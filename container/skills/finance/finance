// ---- Subcommand: review --------------------------------------------------

function cmdReview(args) {
  const txid = args._[0];
  if (!txid) die('Usage: finance review <tx_id> --category X [--subcategory Y] [--learn]');
  if (!args.category) die('--category is required');
  const { rows } = readLedger();
  const idx = rows.findIndex(r => r.tx_id === txid);
  if (idx === -1) die(`tx_id not found: ${txid}`);
  const row = rows[idx];
  row.category = args.category;
  row.subcategory = args.subcategory || '';
  row.confidence = 'high';
  row.flagged_for_review = 'false';
  if (row.tx_type === 'transfer' && !row.transfer_pair_id) {
    row.tx_type = parseFloat(row.amount) >= 0 ? 'income' : 'expense';
  }
  writeLedger(rows);
  if (args.learn) {
    appendLearned({
      pattern: row.description_clean,
      category: args.category,
      subcategory: args.subcategory || '',
      added: new Date().toISOString().slice(0, 10),
    });
  }
  console.log(JSON.stringify({
    updated: row.tx_id,
    category: row.category,
    subcategory: row.subcategory,
    learned: !!args.learn,
  }, null, 2));
}

// ---- Subcommand: review-batch --------------------------------------------

function cmdReviewBatch() {
  let input;
  try {
    input = fs.readFileSync(0, 'utf8');
  } catch (e) {
    die('review-batch reads JSON from stdin: ' + e.message);
  }
  if (!input.trim()) die('review-batch reads JSON from stdin (got empty input)');

  let payload;
  try { payload = JSON.parse(input); }
  catch (e) { die('invalid JSON on stdin: ' + e.message); }

  const decisions = Array.isArray(payload.decisions) ? payload.decisions : [];
  const learnPatterns = Array.isArray(payload.learn_patterns) ? payload.learn_patterns : [];
  if (decisions.length === 0 && learnPatterns.length === 0) {
    die('payload must contain at least one of: decisions[], learn_patterns[]');
  }

  const { rows } = readLedger();
  const byId = new Map(rows.map(r => [r.tx_id, r]));
  const notFound = [];
  let updatedCount = 0;

  for (const d of decisions) {
    if (!d.tx_id || !d.category) {
      notFound.push({ tx_id: d.tx_id || null, reason: 'missing tx_id or category' });
      continue;
    }
    const row = byId.get(d.tx_id);
    if (!row) {
      notFound.push({ tx_id: d.tx_id, reason: 'tx_id not in ledger' });
      continue;
    }
    row.category = d.category;
    row.subcategory = d.subcategory || '';
    row.confidence = 'high';
    row.flagged_for_review = 'false';
    if (row.tx_type === 'transfer' && !row.transfer_pair_id) {
      row.tx_type = parseFloat(row.amount) >= 0 ? 'income' : 'expense';
    }
    updatedCount++;
  }

  // Append learned patterns (dedup by normalised pattern)
  let learnedCount = 0;
  if (learnPatterns.length > 0) {
    const existing = loadLearned();
    const seen = new Set(existing.map(e => normaliseForMatch(e.pattern || '')));
    for (const lp of learnPatterns) {
      if (!lp.pattern || !lp.category) continue;
      const norm = normaliseForMatch(lp.pattern);
      if (seen.has(norm)) continue;
      seen.add(norm);
      existing.push({
        pattern: lp.pattern,
        category: lp.category,
        subcategory: lp.subcategory || '',
        added: new Date().toISOString().slice(0, 10),
      });
      learnedCount++;
    }
    fs.mkdirSync(DATA_DIR, { recursive: true });
    fs.writeFileSync(MERCHANTS_LOCAL_PATH, JSON.stringify(existing, null, 2), 'utf8');
  }

  // Sweep: re-classify any remaining low-confidence rows using the freshly
  // learned patterns. This catches sibling rows that share a merchant the
  // agent just resolved.
  let swept = 0;
  if (learnedCount > 0) {
    for (const r of rows) {
      if (r.confidence !== 'low' && r.flagged_for_review !== 'true') continue;
      if (r.tx_type === 'transfer') continue; // transfers need pair, not classify
      const cls = classify(r.description_raw);
      if (cls.category && cls.confidence !== 'low' &&
          (cls.category !== r.category || cls.subcategory !== r.subcategory)) {
        r.category = cls.category;
        r.subcategory = cls.subcategory;
        r.confidence = cls.confidence;
        r.flagged_for_review = cls.confidence === 'low' ? 'true' : 'false';
        swept++;
      }
    }
  }

  writeLedger(rows);

  console.log(JSON.stringify({
    updated: updatedCount,
    not_found: notFound,
    learned: learnedCount,
    swept,
  }, null, 2));
}

// ---- Subcommand: rebuild -------------------------------------------------

function cmdRebuild(args) {
  if (listRawFiles().length === 0) {
    die(`No raw archive found at ${RAW_DIR}. Refusing to wipe ledger.csv. Run 'finance ingest' first.`);
  }

  const { allParsed, perFile, perBank, errors } = parseAllRaw();
  if (allParsed.length === 0) {
    die(`Raw archive at ${RAW_DIR} contains no parseable transactions. Refusing to wipe ledger.csv.`);
  }

  const { newRows, transferPairs, refundPairs } = runPipeline(allParsed, []);
  const flagged = newRows.filter(r =>
    r.flagged_for_review === 'true' || r.confidence === 'low' || r.confidence === 'medium'
  ).length;

  if (!args['dry-run']) {
    writeLedger(newRows);
  }

  console.log(JSON.stringify({
    files: perFile,
    banks: perBank,
    raw_parsed: allParsed.length,
    ledger_rows: newRows.length,
    transfers_paired: transferPairs.size,
    refunds_paired: refundPairs.size,
    flagged,
    parse_errors: errors,
    dry_run: !!args['dry-run'],
  }, null, 2));
}

// ---- Subcommand: recategorise --------------------------------------------

function cmdRecategorise(args) {
  if (!args.all && !args['tx-id']) die('Provide --all or --tx-id <id>');
  const { rows } = readLedger();
  const target = args.all ? rows : rows.filter(r => r.tx_id === args['tx-id']);
  let changed = 0;
  for (const r of target) {
    if (r.tx_type === 'transfer' && r.transfer_pair_id) continue;
    const cls = classify(r.description_raw);
    if (cls.category && (cls.category !== r.category || cls.subcategory !== r.subcategory)) {
      r.category = cls.category;
      r.subcategory = cls.subcategory;
      r.confidence = cls.confidence;
      r.flagged_for_review = cls.confidence === 'low' ? 'true' : 'false';
      changed++;
    }
  }
  writeLedger(rows);
  console.log(JSON.stringify({ scanned: target.length, changed }, null, 2));
}

// ---- Arg parser ----------------------------------------------------------

function parseArgs(argv) {
  const args = { _: [] };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a.startsWith('--')) {
      const key = a.slice(2);
      const next = argv[i + 1];
      if (next === undefined || next.startsWith('--')) {
        args[key] = true;
      } else {
        args[key] = next;
        i++;
      }
    } else {
      args._.push(a);
    }
  }
  return args;
}

// ---- Entrypoint ----------------------------------------------------------

function help() {
  process.stdout.write([
    'finance — personal-finance ledger CLI',
    '',
    'Usage:',
    '  finance ingest <csv-path> [--bank Investec|Discovery] [--dry-run]',
    '                                        # stash to raw/<bank>.csv only',
    '  finance process [--dry-run]           # categorise & append pending raw → ledger',
    '  finance review <tx_id> --category <cat> [--subcategory <sub>] [--learn]',
    '  finance review-batch                  # reads JSON from stdin',
    '  finance summary [--month YYYY-MM | --year YYYY | --from D --to D]',
    '                  [--group-by category|subcategory|merchant|bank]',
    '                  [--include-transfers] [--refunds-as-income]',
    '  finance search [--category X] [--subcategory Y] [--merchant M]',
    '                 [--min N] [--max N] [--from D] [--to D] [--text "kw"]',
    '                 [--bank X] [--flagged] [--limit N]',
    '  finance budget-check [--month YYYY-MM]',
    '  finance flagged',
    '  finance recategorise [--all | --tx-id <id>]',
    '  finance rebuild [--dry-run]          # wipe & rebuild ledger from raw/',
    '',
    `Data dir: ${DATA_DIR}`,
    `Raw dir : ${RAW_DIR}`,
    '',
  ].join('\n'));
}

function main() {
  const argv = process.argv.slice(2);
  const sub = argv[0];
  const args = parseArgs(argv.slice(1));
  switch (sub) {
    case 'ingest':       return cmdIngest(args);
    case 'process':      return cmdProcess(args);
    case 'review':       return cmdReview(args);
    case 'review-batch': return cmdReviewBatch();
    case 'summary':      return cmdSummary(args);
    case 'search':       return cmdSearch(args);
    case 'budget-check': return cmdBudgetCheck(args);
    case 'flagged':      return cmdFlagged();
    case 'recategorise': return cmdRecategorise(args);
    case 'rebuild':      return cmdRebuild(args);
    case 'help':
    case '--help':
    case '-h':
    case undefined:
      return help();
    default:
      die(`Unknown subcommand: ${sub}. Try 'finance help'.`);
  }
}

main();
